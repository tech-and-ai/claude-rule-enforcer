#!/bin/bash
cd /home/admin/projects/claude-rule-enforcer

# Point CRE at Amp's conversation files
export CRE_SESSIONS_DIR="$HOME/.local/share/amp/threads"

# Get active thread ID for session isolation
if [ -f "$HOME/.local/share/amp/session.json" ]; then
    export CRE_INSTANCE_ID=$(python3 -c "import json;print(json.load(open('$HOME/.local/share/amp/session.json'))['lastThreadId'])" 2>/dev/null)
fi

exec .venv/bin/python -m cre.cli gate --format amp
