# Claude Rule Enforcer — Environment Configuration
# Copy to .env and fill in your values.

# --- L2: LLM Backend (required for advisory layer) ---
CRE_LLM_API_KEY=your-api-key-here
CRE_LLM_API_URL=https://api.openai.com/v1/chat/completions
CRE_LLM_MODEL=gpt-4o-mini
# CRE_LLM_FALLBACK_MODEL=gpt-4o-mini
# CRE_LLM_TIMEOUT=30

# --- L1: PIN Override ---
# Set a PIN to override L1 blocks. Type "override 0000" in chat = approval.
# Only accepted from user messages (the AI cannot forge overrides).
CRE_OVERRIDE_PIN=0000
# CRE_OVERRIDE_TTL=60  # seconds before override expires (default: 60)

# --- L2: Advice Tracking ---
# How many times AI can ignore an ADVISE before it surfaces for your decision.
# You then choose: promote to L1 (hard block), remove (noise), or keep (useful nudge).
CRE_ADVISE_THRESHOLD=5

# --- Paths ---
# CRE_RULES_PATH=./rules.json
# CRE_LOG_PATH=/tmp/cre.log
# CRE_SELF_LEARNING=false
